# Firebase クライアント設定
# 本番接続する場合は Firebase Console > プロジェクト設定 > マイアプリ から取得して .env.local にコピーする
NEXT_PUBLIC_FIREBASE_API_KEY=demo-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=demo-sns-app.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-sns-app
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-sns-app.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# エミュレーター接続を有効化(開発時は true)
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true
