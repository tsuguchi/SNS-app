rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // users: 公開情報(プロフィール)として誰でも閲覧可、本人のみ作成・更新可
    // ※ サインアップ時に username 重複チェック(未ログイン状態)を行うため public read
    match /users/{uid} {
      allow read: if true;
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasOnly(['uid','displayName','username','bio','photoURL','createdAt'])
        && request.resource.data.uid == uid
        && request.resource.data.displayName is string
        && request.resource.data.username is string;
      allow update: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;
    }

    // posts: 誰でも閲覧可、ログイン者は自分名義で作成可、自分の投稿のみ削除可、更新は不可(編集機能は将来)
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.content is string
        && request.resource.data.content.size() <= 280
        && request.resource.data.imageUrls is list
        && request.resource.data.imageUrls.size() <= 4
        && request.resource.data.likeCount == 0
        && request.resource.data.replyCount == 0
        && request.resource.data.createdAt == request.time;
      // likeCount / replyCount を ±1 のみ更新可(client-side counter)
      // 既存投稿に replyCount フィールドがないケースに備えて get(...) でデフォルト 0 を使う
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount', 'replyCount'])
        && (
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount'])
            && (request.resource.data.likeCount == resource.data.get('likeCount', 0) + 1
                || request.resource.data.likeCount == resource.data.get('likeCount', 0) - 1))
          ||
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replyCount'])
            && (request.resource.data.replyCount == resource.data.get('replyCount', 0) + 1
                || request.resource.data.replyCount == resource.data.get('replyCount', 0) - 1))
        );
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    // follows: followerId__followingId をドキュメントIDに(自分→相手の関係)
    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.followerId == request.auth.uid
        && request.resource.data.followerId != request.resource.data.followingId
        && followId == request.resource.data.followerId + '__' + request.resource.data.followingId;
      allow delete: if isSignedIn() && resource.data.followerId == request.auth.uid;
      allow update: if false;
    }

    // notifications: 通知。受信者のみ read 可、送信側ユーザーが create
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow list: if isSignedIn(); // クエリ自体は許可、where 句で recipientId 制限を実施
      allow create: if isSignedIn()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.recipientId is string
        && request.resource.data.recipientId != request.auth.uid
        && request.resource.data.type in ['like','follow','reply']
        && request.resource.data.read == false;
      // 受信者のみ read フラグの変更可
      allow update: if isSignedIn() && resource.data.recipientId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && resource.data.recipientId == request.auth.uid;
    }

    // likes: postId__userId をドキュメントIDとして一意性を担保
    match /likes/{likeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && likeId == request.resource.data.postId + '__' + request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }
  }
}
